{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.Extensions.Http": "Warning"
    },
    "EventLog": {
      "SourceName": "WeatherForecastService",
      "LogName": "Application"
    }
  },
  "ConnectionStrings": {
    "MeteoDb": "Data Source=localhost\\SQLEXPRESS;Initial Catalog=DBNAME;User ID=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;Encrypt=True"
  },
  "WeatherService": {
    "ScheduleHour": 15,
    "ScheduleMinute": 0,
    "OpenMeteoBaseUrl": "https://api.open-meteo.com/v1/forecast",
    "OpenMeteoArchiveBaseUrl": "https://archive-api.open-meteo.com/v1/archive",
    "BackfillFromDate": null
  }
}
